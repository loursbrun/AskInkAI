# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=remplace_par_64_caracteres_hex

# Générer avec : node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=remplace_par_secret_aleatoire

# URL du frontend (pour CORS). En dev : http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Port d'écoute du serveur
PORT=3001

# Modèle Claude utilisé pour les réponses
CLAUDE_MODEL=claude-haiku-4-5-20251001

# production | development
NODE_ENV=development
